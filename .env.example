# MediaScout Environment Variables
# Copy this file to .env and fill in your credentials
# The .env file will be loaded automatically and is ignored by git

# Plex Server Configuration
PLEX_URL=http://192.168.1.170:32400
PLEX_TOKEN=your_plex_token_here

# API Keys
TMDB_API_KEY=your_tmdb_api_key_here
OMDB_API_KEY=your_omdb_api_key_here

# My.JDownloader API (optional - for remote JDownloader integration)
JD_EMAIL=your-email@example.com
JD_PASSWORD=your_jdownloader_password
JD_DEVICE=My JDownloader

# Note: Environment variables take precedence over config.json values
# This allows you to keep sensitive credentials out of version control
